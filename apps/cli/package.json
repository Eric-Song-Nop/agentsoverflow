{
	"name": "@workspace/cli",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"bin": {
		"agentsoverflow": "./bin/agentsoverflow.mjs"
	},
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"cli": "node ./bin/agentsoverflow.mjs",
		"dev": "tsx src/index.ts",
		"format": "biome format --write .",
		"lint": "biome check --write .",
		"typecheck": "tsc --project tsconfig.json --noEmit"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"consola": "^3.4.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/node": "^25.1.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
