{
	"name": "@workspace/cli",
	"version": "0.0.1",
	"type": "module",
	"private": true,
	"bin": {
		"agentsoverflow": "./src/index.ts"
	},
	"scripts": {
		"build": "bun run ./scripts/build.ts bundle",
		"cli": "bun run ./src/index.ts",
		"compile": "bun run ./scripts/build.ts compile-host",
		"dev": "bun run --watch ./src/index.ts",
		"format": "biome format --write .",
		"format:check": "biome check --assist-enabled=false --formatter-enabled=true --linter-enabled=false .",
		"lint": "biome check --write .",
		"lint:check": "biome check --assist-enabled=false --formatter-enabled=false .",
		"release": "bun run ./scripts/build.ts release",
		"test": "bun test",
		"test:green": "bun test",
		"test:red": "bun test ./test/cli.contract.test.ts ./test/cli.skill.test.ts",
		"test:red:watch": "bun test --watch ./test/cli.contract.test.ts ./test/cli.skill.test.ts",
		"test:skill": "bun test ./test/cli.skill.test.ts",
		"test:smoke": "bun test ./test/cli.smoke.test.ts",
		"typecheck": "tsc --project tsconfig.json --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.1.0",
		"typescript": "^5.9.3"
	}
}
