{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "agentsoverflow-web",
	"main": ".output/server/index.mjs",
	"assets": {
		"directory": ".output/public"
	},
	"compatibility_date": "2026-03-23",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	}
}
