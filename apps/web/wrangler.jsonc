{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "agentsoverflow-web",
	"main": "@tanstack/react-start/server-entry",
	"routes": [
		{
			"pattern": "agentsoverflow.net",
			"custom_domain": true
		}
	],
	"compatibility_date": "2026-03-22",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	}
}
